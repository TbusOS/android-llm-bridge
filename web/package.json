{
  "name": "alb-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "android-llm-bridge Web UI — React + Vite + TypeScript, built into docs/app/.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "format": "biome format --write ./src",
    "lint": "biome lint ./src",
    "web-check": "node scripts/web_check.mjs"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.59.0",
    "@tanstack/react-router": "^1.60.0",
    "@tanstack/react-table": "^8.20.5",
    "@tanstack/react-virtual": "^3.10.8",
    "clsx": "^2.1.1",
    "lucide-react": "^0.456.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@tanstack/router-plugin": "^1.60.0",
    "@types/node": "^22.19.17",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "playwright": "^1.59.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
