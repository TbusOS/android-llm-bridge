# alb — environment configuration template.
#
# Usage:
#   cp .env.example .env.local
#   # edit .env.local with your real deployment values
#   # .env.local is gitignored; never commit it
#
# Priority (highest first):
#   1. Shell exports (`export X=... ` in ~/.bashrc or `X=... alb …`)
#   2. .env.local at repo root
#   3. .env at repo root
#   4. Library defaults
#
# All keys below are optional. Uncomment and set only what you need to
# override. Values shown are safe localhost defaults.

# ── Agent / LLM backend (src/alb/agent/backends) ─────────────────────
# Ollama daemon URL used by `alb chat` and POST /chat when no explicit
# --ollama-url / ollama_url is passed.
#ALB_OLLAMA_URL=http://localhost:11434

# Default model tag for the Agent. Library default: qwen2.5:3b.
# Practical recommendations for CPU-only servers:
#   - gemma4:26b    — MoE, ~18 GB, ~4s/AgentLoop, native tool-calling
#   - gemma4:e4b    — Matryoshka 4B, ~9 GB, same speed, less RAM
#   - gpt-oss:20b   — MoE, ~14 GB, fallback for EN heavy reasoning
#ALB_OLLAMA_MODEL=qwen2.5:3b

# Backend name passed to get_backend(). Currently: ollama (shipping) /
# openai-compat (M3) / llama-cpp (M3) / anthropic (M3).
#ALB_AGENT_BACKEND=ollama

# ── Core infrastructure (src/alb/infra) ──────────────────────────────
# Alternate config.toml path. Default: ~/.config/alb/config.toml
#ALB_CONFIG=/path/to/config.toml

# Active profile name. Default: reads from config.toml's default_profile.
#ALB_PROFILE=default

# Workspace root (where sessions / artifacts land). Default: ./workspace
#ALB_WORKSPACE=/path/to/workspace

# ── Transport layer ──────────────────────────────────────────────────
# Explicit adb binary path (if not on PATH).
#ALB_ADB_PATH=/usr/bin/adb

# Force a specific transport for the duration of a run.
#   adb | ssh | serial | hybrid
#ALB_TRANSPORT=hybrid

# ── FastAPI server (alb-api) ─────────────────────────────────────────
#ALB_API_HOST=0.0.0.0
#ALB_API_PORT=8765

# ── SSH transport (for `alb setup ssh`) ──────────────────────────────
#ALB_SSH_HOST=192.168.1.42
#ALB_SSH_USER=root
#ALB_SSH_KEY=~/.ssh/alb-device
